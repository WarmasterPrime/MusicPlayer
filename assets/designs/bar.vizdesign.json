{
  "name": "bar",
  "label": "Bar",
  "version": 1,
  "type": "2d",
  "description": "Vertical frequency bars with mirrored layout and brightness gradient",
  "audio": {
    "toff": 150,
    "bassRange": 0.03,
    "bassNormDivisor": 150
  },
  "config": {},
  "particles": null,
  "subroutines": {},
  "render": {
    "steps": [
      { "type": "let", "name": "totalVisWidth", "expr": "=barWidth * (binCount * 2)" },
      { "type": "let", "name": "startX", "expr": "=(width - totalVisWidth) / 2" },
      { "type": "let", "name": "x", "expr": "=startX" },
      { "type": "let", "name": "xx", "expr": "=startX + totalVisWidth / 2" },
      { "type": "let", "name": "i", "expr": "=0" },
      { "type": "let", "name": "u", "expr": "=0" },
      { "type": "let", "name": "ii", "expr": "=binCount - barWidth" },
      {
        "type": "loop",
        "var": "o",
        "from": "=binCount",
        "to": 0,
        "direction": "down",
        "body": [
          { "type": "let", "name": "y", "expr": "=((data[o] + toff) / barHeight) * maxHeight" },
          { "type": "let", "name": "calc", "expr": "=min(1.0, (y / height) * 1.6 + 0.15)" },
          { "type": "setStyle", "prop": "fillStyle", "expr": "='rgb(' + (r * calc) + ',' + (g * calc) + ',' + (b * calc) + ')'" },
          { "type": "fillRect", "x": "=x + (i * xOffset)", "y": "=height - y", "w": "=barWidth", "h": "=height" },
          { "type": "accumulate", "var": "x", "expr": "=x + barWidth" },
          { "type": "accumulate", "var": "i", "expr": "=i + 1" },
          { "type": "let", "name": "y2", "expr": "=((data[u] + toff) / barHeight) * maxHeight" },
          { "type": "let", "name": "calc2", "expr": "=min(1.0, (y2 / height) * 1.6 + 0.15)" },
          { "type": "setStyle", "prop": "fillStyle", "expr": "='rgb(' + (r * calc2) + ',' + (g * calc2) + ',' + (b * calc2) + ')'" },
          { "type": "fillRect", "x": "=xx + (ii * xOffset)", "y": "=height - y2", "w": "=barWidth", "h": "=height" },
          {
            "type": "conditional",
            "condition": "=data[u] !== 0",
            "then": [
              { "type": "accumulate", "var": "tre", "expr": "=tre + data[u] + toff" }
            ]
          },
          { "type": "accumulate", "var": "u", "expr": "=u + 1" },
          { "type": "accumulate", "var": "xx", "expr": "=xx + barWidth" },
          { "type": "accumulate", "var": "ii", "expr": "=ii + 1" }
        ]
      }
    ]
  }
}
