{
  "name": "curvedLines",
  "label": "Curved Lines",
  "version": 1,
  "type": "2d",
  "description": "Smooth quadratic curves through frequency data points with optional fill",
  "audio": {
    "toff": 150,
    "bassRange": 0.03,
    "bassNormDivisor": 150
  },
  "config": {},
  "particles": null,
  "subroutines": {},
  "render": {
    "steps": [
      { "type": "let", "name": "bw1", "expr": "=barWidth + 1" },
      { "type": "let", "name": "totalWidth", "expr": "=bw1 * (binCount * 2)" },
      { "type": "let", "name": "startX", "expr": "=(width - totalWidth) / 2" },
      { "type": "let", "name": "x", "expr": "=startX" },
      { "type": "let", "name": "xx", "expr": "=startX + (bw1 * binCount)" },
      { "type": "let", "name": "i", "expr": "=0" },
      { "type": "let", "name": "u", "expr": "=0" },
      { "type": "let", "name": "ii", "expr": "=binCount - barWidth" },
      { "type": "let", "name": "lastCalc", "expr": "=0" },
      { "type": "setStyle", "prop": "lineWidth", "expr": "=2" },
      { "type": "initArray", "array": "leftPts" },
      { "type": "initArray", "array": "rightPts" },
      {
        "type": "loop",
        "var": "o",
        "from": "=binCount",
        "to": 0,
        "direction": "down",
        "body": [
          { "type": "let", "name": "y", "expr": "=((data[o] + toff) / barHeight) * maxHeight" },
          { "type": "let", "name": "calc", "expr": "=min(1.0, (y / height) * 1.6 + 0.15)" },
          { "type": "accumulate", "var": "lastCalc", "expr": "=calc" },
          { "type": "pushArray", "array": "leftPts", "value": { "x": "=x + (i * xOffset)", "y": "=height - y" } },
          { "type": "accumulate", "var": "x", "expr": "=x + bw1" },
          { "type": "accumulate", "var": "i", "expr": "=i + 1" },
          { "type": "let", "name": "y2", "expr": "=((data[u] + toff) / barHeight) * maxHeight" },
          {
            "type": "conditional",
            "condition": "=data[u] !== 0",
            "then": [
              { "type": "accumulate", "var": "tre", "expr": "=tre + data[u] + toff" }
            ]
          },
          { "type": "accumulate", "var": "u", "expr": "=u + 1" },
          { "type": "accumulate", "var": "xx", "expr": "=xx + bw1" },
          { "type": "accumulate", "var": "ii", "expr": "=ii + 1" }
        ]
      },
      {
        "type": "let", "name": "_dummy", "expr": "=(function(){ var u2=0, xx2=startX + (bw1 * binCount), ii2=binCount - barWidth; for(var oo=binCount; oo>=0; oo--){ var yy=((data[u2]+toff)/barHeight)*maxHeight; _arrays.rightPts.push({x: xx2+(ii2*xOffset), y: height-yy}); u2++; xx2+=bw1; ii2++; } return 0; })()"
      },
      { "type": "let", "name": "colorStr", "expr": "='rgb(' + (r * lastCalc) + ',' + (g * lastCalc) + ',' + (b * lastCalc) + ')'" },
      {
        "type": "conditional",
        "condition": "=fillPolygon",
        "then": [
          {
            "type": "drawArrayPath",
            "arrays": ["leftPts", "rightPts"],
            "startX": "=_arrays.leftPts[0] ? _arrays.leftPts[0].x : startX",
            "startY": "=height",
            "endX": "=_arrays.rightPts.length ? _arrays.rightPts[_arrays.rightPts.length-1].x : width",
            "endY": "=height",
            "closePath": true,
            "fill": "=colorStr",
            "curve": true
          }
        ],
        "else": [
          {
            "type": "drawArrayPath",
            "arrays": ["leftPts", "rightPts"],
            "stroke": "=colorStr",
            "lineWidth": "=2",
            "curve": true
          }
        ]
      }
    ]
  }
}
